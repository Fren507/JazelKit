{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": false,
    "outDir": "demo/public/src",
    "rootDir": "demo/src/scripts",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    "baseUrl": ".",
    "paths": {
      "$lib/*": ["demo/src/lib/*"],
      "$components/*": ["demo/src/components/*"],
      "$client/*": ["demo/src/*"],
      "$server/*": ["server/*"]
    }
  },
  "include": ["demo/src/scripts", "server/**/*", "demo/main.js", "demo/main.js"]
}
